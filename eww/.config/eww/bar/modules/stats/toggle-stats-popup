#!/usr/bin/env sh
set -eu

eww_bin=/etc/profiles/per-user/mikhail/bin/eww
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/eww"

if "$eww_bin" --config "$config_dir" active-windows | grep -q '^stats-popup-window:'; then
  if [ "$($eww_bin --config "$config_dir" get stats_popup_pinned)" = true ]; then
    "$eww_bin" --config "$config_dir" close stats-popup-window
    exec "$eww_bin" --config "$config_dir" update stats_popup_pinned=false
  fi

  exec "$eww_bin" --config "$config_dir" update stats_popup_pinned=true
fi

"$eww_bin" --config "$config_dir" open stats-popup-window
exec "$eww_bin" --config "$config_dir" update stats_popup_pinned=true
