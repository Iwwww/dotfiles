#!/usr/bin/env sh
set -eu

metric=${1:-}
duration_ms=5000
phase_ms=1000
state_dir="${XDG_RUNTIME_DIR:-/tmp}/eww-stats-critical-pulse"
state_file="$state_dir/$metric"
eww_bin=${EWW_CMD:-$(command -v eww)}
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/eww"
critical_threshold=$("$eww_bin" --config "$config_dir" get stats_critical_threshold 2>/dev/null || printf 90)

case "$critical_threshold" in
  ''|*[!0-9]*) critical_threshold=90 ;;
esac

is_critical() {
  case "$metric" in
    cpu)
      "$eww_bin" --config "$config_dir" get EWW_CPU 2>/dev/null | jq -e --argjson threshold "$critical_threshold" '(.avg // 0) >= $threshold' >/dev/null
      ;;
    ram)
      "$eww_bin" --config "$config_dir" get EWW_RAM 2>/dev/null | jq -e --argjson threshold "$critical_threshold" '(.used_mem_perc // 0) >= $threshold' >/dev/null
      ;;
    temp)
      "$eww_bin" --config "$config_dir" get temperature_state 2>/dev/null | jq -e '.class == "critical"' >/dev/null
      ;;
    *)
      return 1
      ;;
  esac
}

mkdir -p "$state_dir"

if ! is_critical; then
  rm -f "$state_file"
  printf '\n'
  exit 0
fi

now_ms=$(date +%s%3N)

if [ -f "$state_file" ]; then
  IFS= read -r start_ms <"$state_file" || start_ms=$now_ms
else
  start_ms=$now_ms
  printf '%s\n' "$start_ms" >"$state_file"
fi

case "$start_ms" in
  ''|*[!0-9]*)
    start_ms=$now_ms
    printf '%s\n' "$start_ms" >"$state_file"
    ;;
esac

elapsed_ms=$((now_ms - start_ms))

if [ "$elapsed_ms" -ge "$duration_ms" ]; then
  printf '\n'
  exit 0
fi

if [ $(((elapsed_ms / phase_ms) % 2)) -eq 0 ]; then
  printf 'pulse-on\n'
else
  printf '\n'
fi
