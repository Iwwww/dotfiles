{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "compaction": {
    "auto": false,
    "prune": false,
    "reserved": 8192
  },
  "plugin": [
    "opencode-helicone-session",
    "opencode-vibeguard",
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-agent-skills",
    "@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest",
    "oc-codex-multi-auth",
    "@frankhommers/opencode-yolo"
  ],
  "provider": {
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://firpc-1:11434/v1"
      },
      "models": {
        "gemma4:e4b-32k": {
          "name": "gemma4:e4b-32k",
          "tool_call": true,
          "options": {
            "temperature": 0.1
          }
        },
        "gemma4:e4b-125k": {
          "name": "gemma4:e4b-125k",
          "tool_call": true,
          "options": {
            "temperature": 0.1
          }
        },
        "gemma4:26b-62k": {
          "name": "gemma4:26b-62k",
          "tool_call": true,
          "options": {
            "temperature": 0.1
          }
        },
        "ministral-3:8b-OC32k": {
          "id": "ministral-3:8b-OC32k",
          "name": "Ministral 3 8B (32k)",
          "options": {
            "temperature": 0.1
          }
        }
      }
    }
  },
  "agent": {
    "explore": {
      "disable": true,
      "options": {},
      "permission": {}
    },
    "general": {
      "disable": true,
      "options": {},
      "permission": {}
    }
  },
  "mcp": {
    "contextplus": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "contextplus"
      ],
      "enabled": true
    }
  },
  "disabled_providers": [
    "ollama"
  ]
}