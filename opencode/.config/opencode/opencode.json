              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        }
      }
    }
  },
  "mcp": {
    "open-design": {
      "type": "local",
      "command": [
        "od",
        "mcp",
        "--daemon-url",
        "http://127.0.0.1:7456"
      ],
      "enabled": true
    },
    "wireshark": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-wireshark"
      ],
      "enabled": true,
      "environment": {}
    },
    "searxng": {
      "type": "local",
      "command": ["npx", "-y", "mcp-searxng"],
      "environment": {
        "SEARXNG_URL": "http://127.0.0.1:8080"
      },
      "enabled": true,
      "timeout": 30000
    }
  },
  "disabled_providers": [
    "ollama"
  ]
}
