{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8192
  },
  "plugin": [
    "opencode-helicone-session",
    "opencode-vibeguard",
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-agent-skills",
    "@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest"
  ],
  "provider": {
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://firpc-1.tail31cf05.ts.net:11434/v1"
      },
      "models": {
        "qwen3.5:9b": {
          "name": "qwen3.5:9b",
          "_launch": true,
          "tool_call": true,
          "options": {
            "temperature": 0.1
          },
        },
        "gemma4:e4b-32k": {
          "name": "gemma4:e4b-32k",
          "_launch": true,
          "tool_call": true,
          "options": {
            "temperature": 0.1
          },
          "maxTokens": 16384
        },
        "gemma4:e4b-125k": {
          "name": "gemma4:e4b-125k",
          "_launch": true,
          "tool_call": true,
          "options": {
            "temperature": 0.1
          },
          "maxTokens": 125000
        },
        "gemma4:26b-62k": {
          "name": "gemma4:26b-62k",
          "_launch": true,
          "tool_call": true,
          "options": {
            "temperature": 0.1
          },
          "maxTokens": 62000
        },
        "ministral-3:8b-OC32k": {
          "_launch": true,
          "id": "ministral-3:8b-OC32k",
          "name": "Ministral 3 8B (32k)",
          "options": {
            "temperature": 0.1
          },
          "maxTokens": 16384
        }
      }
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "@upstash/context7-mcp@latest"],
      "enabled": true
    },
    "better-icons": {
      "type": "local",
      "command": ["npx", "better-icons"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "contextplus": {
      "type": "local",
      "command": ["npx", "-y", "contextplus"],
      "enabled": true
    }
  }
}
