{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": false,
    "prune": false,
    "reserved": 8192
  },
  "plugin": [
    "opencode-vibeguard@latest",
    "opencode-agent-skills@latest",
    "@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest",
    "oc-codex-multi-auth@latest",
    //"@guard22/opencode-multi-auth-codex@latest"
    //"oc-codex-multi-auth@latest",
    //"@frankhommers/opencode-yolo",
    //"@guard22/opencode-multi-auth-codex@latest"
    //"opencode-helicone-session",
    //"opencode-vibeguard",
    //"@franlol/opencode-md-table-formatter@latest",
    //"opencode-agent-skills",
    //"@tarquinen/opencode-dcp@latest",
    //"@mohak34/opencode-notifier@latest",
    //"oc-codex-multi-auth",
    //"@frankhommers/opencode-yolo"
  ],
  "provider": {
    "openai": {
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": [
          "reasoning.encrypted_content"
        ],
        "store": false
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT 5.5 (OAuth)",
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.5-fast": {
          "name": "GPT 5.5 Fast (OAuth)",
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.4": {
          "name": "GPT 5.4 (OAuth)",
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
