{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8192
  },
  "plugin": [
    "opencode-helicone-session",
    "opencode-vibeguard",
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-agent-skills",
    //"@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest"
  ],
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://firpc-1.tail31cf05.ts.net:1234/v1"
      },
      "models": {
        "omnicoder-9b-claude-opus-high-reasoning-distill": {
          "name": "OmniCoder 9b opus",
          "temperature": true,
          "options": {
            "temperature": 0.3,
            "topP": 0.95,
            "maxTokens": 220000,
            "frequencyPenalty": 0.1,
            "presencePenalty": 0.15
          }
        },
        "qwen3-14b-claude-4.5-opus-high-reasoning-distill": {
          "name": "Qwen 3 14b opus",
          "temperature": true,
          "options": {
            "temperature": 0.2,
            "topP": 0.9,
            "maxTokens": 40000,
            "frequencyPenalty": 0.1,
            "presencePenalty": 0.1
          }
        },
        "qwen/qwen3.6-35b-a3b": {
          "name": "Qwen 3.6 35b a3b",
          "temperature": true,
          "options": {
            "temperature": 0.2,
            "topP": 0.9,
            "maxTokens": 64000,
            "frequencyPenalty": 0.1,
            "presencePenalty": 0.1
          }
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "@upstash/context7-mcp@latest"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "contextplus": {
      "type": "local",
      "command": ["npx", "-y", "contextplus"],
      "enabled": true
    }
  }
}
