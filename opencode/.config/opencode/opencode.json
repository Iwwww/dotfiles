{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8192
  },
  "plugin": [
    "opencode-helicone-session",
    "opencode-vibeguard",
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-agent-skills",
    "@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest"
  ],
  "provider": {
    "gateway": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Gateway",
      "options": {
        "baseURL": "http://46.173.17.179:3188/v1",
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6"
        },
        "claude-sonnet-4-6": {
          "name": "Sonnet 4.6"
        },
        "gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro"
        },
        "gpt-5.5": {
          "name": "GPT 5.5"
        },
        "gpt-5.4": {
          "name": "GPT 5.4"
        }
      }
    },
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://firpc-1:11434/v1"
      },
      "models": {
        "gemma4:e4b-32k": {
          "name": "gemma4:e4b-32k",
          "_launch": true,
          "tool_call": true,
          "options": {
            "temperature": 0.1
          },
          "maxTokens": 16384
        },
        "gemma4:e4b-125k": {
          "name": "gemma4:e4b-125k",
          "_launch": true,
          "tool_call": true,
          "options": {
            "temperature": 0.1
          },
          "maxTokens": 125000
        },
        "gemma4:26b-62k": {
          "name": "gemma4:26b-62k",
          "_launch": true,
          "tool_call": true,
          "options": {
            "temperature": 0.1
          },
          "maxTokens": 62000
        },
        "ministral-3:8b-OC32k": {
          "_launch": true,
          "id": "ministral-3:8b-OC32k",
          "name": "Ministral 3 8B (32k)",
          "options": {
            "temperature": 0.1
          },
          "maxTokens": 16384
        }
      }
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "@upstash/context7-mcp@latest"],
      "enabled": true
    },
    "contextplus": {
      "type": "local",
      "command": ["npx", "-y", "contextplus"],
      "enabled": true
    }
  }
}
