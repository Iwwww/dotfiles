#!/usr/bin/env sh
set -eu

active=${ACTIVE_PLAYER:-}
pflag=

if [ -n "$active" ]; then
  pflag="-p $active"
fi

players=$(
  playerctl -l 2>/dev/null \
    | sed 's/\.instance.*//' \
    | sort -u \
    | while IFS= read -r player; do
        [ -n "$player" ] || continue
        printf '%s\t%s\n' "$player" "$(playerctl -p "$player" status 2>/dev/null || printf Stopped)"
      done \
    | jq -Rsc '[split("\n")[] | select(length > 0) | split("\t") | {name:.[0], status:.[1]}]'
)

if [ -z "$active" ]; then
  active=$(printf '%s' "$players" | jq -r '(.[] | select(.status == "Playing") | .name)[0] // .[0].name // ""')
  if [ -n "$active" ]; then
    pflag="-p $active"
  fi
fi

if ! status=$(playerctl $pflag status 2>/dev/null); then
  jq -cn --argjson players "${players:-[]}" \
    '{class:"stopped",text:"",title:"",artist:"",album:"",art:"",player:"",length:0,position:0,progress:0,players:$players}' > /tmp/quickshell-media.json
  exit 0
fi

meta=$(playerctl $pflag metadata --format '{{artist}}	{{title}}	{{album}}	{{playerName}}	{{mpris:artUrl}}	{{mpris:length}}' 2>/dev/null || printf '\t\t\t\t\t')
artist=$(printf '%s' "$meta" | cut -f1)
title=$(printf '%s' "$meta" | cut -f2)
album=$(printf '%s' "$meta" | cut -f3)
player=$(printf '%s' "$meta" | cut -f4)
art_url=$(printf '%s' "$meta" | cut -f5)
length_us=$(printf '%s' "$meta" | cut -f6)

art=
case "$art_url" in
  file://*) art=${art_url#file://} ;;
  /*) art=$art_url ;;
esac
[ -n "$art" ] && [ ! -f "$art" ] && art=

length=0
if [ -n "$length_us" ] && [ "$length_us" != 0 ]; then
  length=$((length_us / 1000000))
fi

position=$(playerctl $pflag position 2>/dev/null | awk '{printf "%d", $1}' || printf 0)
progress=0
if [ "$length" -gt 0 ]; then
  progress=$((position * 100 / length))
fi
[ "$progress" -gt 100 ] && progress=100

text=$status
[ -n "$title" ] && text=$title
[ -n "$artist" ] && [ -n "$title" ] && text="$artist - $title"

class=stopped
[ "$status" = Playing ] && class=playing
[ "$status" = Paused ] && class=paused

jq -cn \
  --arg class "$class" \
  --arg text "$text" \
  --arg title "$title" \
  --arg artist "$artist" \
  --arg album "$album" \
  --arg art "$art" \
  --arg player "$player" \
  --argjson length "$length" \
  --argjson position "$position" \
  --argjson progress "$progress" \
  --argjson players "${players:-[]}" \
  '{class:$class,text:$text,title:$title,artist:$artist,album:$album,art:$art,player:$player,length:$length,position:$position,progress:$progress,players:$players}' > /tmp/quickshell-media.json
