#!/usr/bin/env sh
set -eu

muted=$(pamixer --get-mute 2>/dev/null || printf false)
value=$(pamixer --get-volume 2>/dev/null || printf 0)
text=$value

if [ "$value" -ge 100 ]; then
  text=00
elif [ "$value" -lt 10 ]; then
  text=0$value
fi

jq -cn --argjson muted "$muted" --argjson value "$value" --arg text "$text" \
  '{muted:$muted,value:$value,text:$text}' > /tmp/quickshell-volume.json
