#!/usr/bin/env sh
set -eu

RISTATE=${RISTATE:-/etc/profiles/per-user/mikhail/bin/ristate}
JQ=${JQ:-/run/current-system/sw/bin/jq}

if [ ! -x "$RISTATE" ]; then RISTATE=$(command -v ristate || true); fi
if [ ! -x "$JQ" ]; then JQ=$(command -v jq || true); fi
if [ -z "${RISTATE:-}" ] || [ -z "${JQ:-}" ]; then exit 1; fi

jqf=$(mktemp)
trap 'rm -f "$jqf"' EXIT

cat > "$jqf" << 'JQEOF'
def flat_values: [ .[]?[]? ] | unique;
(.tags // {} | flat_values | map(tostring)) as $focused
| (.viewstag // {} | flat_values | map(tostring)) as $occupied
| (.urgency // {} | flat_values | map(tostring)) as $urgent
| [range(1; 21)
  | tostring as $id
  | select(($focused | index($id)) or ($occupied | index($id)) or ($urgent | index($id)))
  | {
      id: $id,
      class: ([
        "tag",
        (if ($focused | index($id)) then "focused" else empty end),
        (if ($occupied | index($id)) then "occupied" else empty end),
        (if ($urgent | index($id)) then "urgent" else empty end)
      ] | join(" "))
    }]
JQEOF

tmpf=$(mktemp)
timeout 4 sh -c \
  '"$1" --tags --views-tag --urgency 2>/dev/null | "$2" --unbuffered -cf "$3"' \
  _ "$RISTATE" "$JQ" "$jqf" | while IFS= read -r line; do
    [ "$line" = "[]" ] && continue
    printf '%s\n' "$line"
    break
  done > "$tmpf"

[ -s "$tmpf" ] && mv "$tmpf" /tmp/quickshell-tags.json || rm -f "$tmpf"
