#!/usr/bin/env sh
set -eu

if ! command -v powerprofilesctl >/dev/null 2>&1; then
  printf '%s\n' '{"available":false,"text":"","class":"missing","profile":""}' > /tmp/quickshell-power.json
  exit 0
fi

profile=$(powerprofilesctl get 2>/dev/null || printf missing)

case "$profile" in
  performance) icon=󰎪 ;;
  power-saver) icon=󰎤 ;;
  balanced) icon=󰎧 ;;
  *)
    printf '%s\n' '{"available":false,"text":"","class":"missing","profile":""}' > /tmp/quickshell-power.json
    exit 0
    ;;
esac

jq -cn --arg text "$icon" --arg class "$profile" --arg profile "$profile" \
  '{available:true,text:$text,class:$class,profile:$profile}' > /tmp/quickshell-power.json
