[
  {
    "position": "right",
    "modules-left": [
      "river/layout",
      "river/tags", "mpris"],
    "modules-right": [
      "group/stat",
      "custom/codexbar",
      "pulseaudio",
      "power-profiles-daemon",
      "group/hardware",
      "tray",
      "clock",
    ],
    "mpris": {
      "format": "{player_icon} {dynamic}",
      "format-paused": "{status_icon} <i>{dynamic}</i>",
      "player-icons": {
        "default": "в–¶",
        "mpv": "пЌ®",
        "spotify": "п†ј",
        "firefox": "у°€№",
        "chromium": "оµЂ",
      },
      "status-icons": {
        "paused": "пЃЊ",
      },
      "title-len": 40,
      "album-len": 15,
      "artist-len": 10,
      "dynamic-len": 40,
      // "interval": 10,
      "rotate": 270,
    },
    "river/tags": {
      "hide-vacant": true,
      "num-tags": 20,
    },
    "river/layout": {
        "format": "{}",
    },
    "group/hardware": {
        "orientation": "horizontal",
        "modules": [
			"backlight",
            "battery"
        ]
    },
    "group/stat": {
        "orientation": "vertical",
        "modules": [
            "network",
            "cpu",
            "memory",
            "temperature",
        ]
    },
    "dwl/window": {
      "format": "{}",
      "max-length": 30,
      "hide-inactive": false,
      "hide-empty": false,
      "align": 0,
      "rewrite": {
        "(.*) - Mozilla Firefox": "рџЊЋ $1",
        "(.*) - zsh": "> [$1]",
      },
      "rotate": 270,
    },
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "пЃ®",
        "deactivated": "пЃ°",
      },
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip": false,
      "format-icons": {
        "default": "default",
        "performance": "у°ЋЄ",
        "balanced": "у°Ћ§",
        "power-saver": "у°Ћ¤",
      },
    },
    "custom/codexbar": {
      "exec": "codexbar --format '{session_reset}'",
      "return-type": "json",
      "interval": 300,
      "signal": 12,
      "rotate": 270,
      "tooltip": true,
      "on-click": "xdg-open https://chatgpt.com/codex/settings/usage",
    },
    "tray": {
      "icon-size": 21,
      "spacing": 10,
    },
    "clock": {
      "format": "{:%H\n<span overline=\"single\">%M</span>\n<span color='gray'>%d</span>}",
      "tooltip-format": "<tt>{calendar}</tt>",
                "calendar": {
                     "mode"          : "month",
                     "mode-mon-col"  : 3,
                     "weeks-pos"     : "right",
                     "on-scroll"     : 1,
                     "on-click-right": "mode",
                     "format": {
                          "months":     "<span color='#ffead3'><b>{}</b></span>",
                          "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                          "weeks":      "<span color='#99ff6d'><b>W{}</b></span>",
                          "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                          "today":      "<span color='#dfdfdf' background='#cf4699'><b><u>{}</u></b></span>"
                     }
                },
      "tooltip": true,
    },
    "cpu": {
      "states": {
          "warning": 70,
          "critical": 90
      },
      "align": 0,
      "format": "п‹›\n{usage}",
    },
    "memory": {
      "states": {
          "warning": 85,
          "critical": 95 
      },
      "align": 1,
      "format": "ої…\n{}",
    },
    "temperature": {
      "thermal-zone": 2,
      "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
      "critical-threshold": 89,
      "format-critical": "{icon} {temperatureC}",
      "format": "{icon} {temperatureC}",
      "format-icons": ["п‹‹", "п‹Љ", "п‹‰", "п‹‡"],
    },
    "backlight": {
      "scroll-step": 5,
      "format": "{icon}",
      "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"],
      "tooltip-format": "{icon} {percent}%",
    },
    "battery": {
      "states": {
        "good": 95,
        "warning": 20,
        "critical": 10,
      },
      "format": "{icon}",
      "format-charging": "{capacity}",
      "format-plugged": "у°‚„",
      "format-alt": "{capacity}",
      "format-icons": ["у°‚Ћ", "у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"],
      "tooltip-format": "{capacity}%\n{time}",
      "full-at": 98,
    },
    "network": {
      "format-wifi": "{icon} {essid}",
      "format-ethernet": "у°›і Ethernet",
      "format-linked": "пћ– {ifname} (No IP)",
      "format-disconnected": "у°¤­ ",
      "format-icons": ["у°¤Ї", "у°¤џ", "у°¤ў", "у°¤Ґ", "у°¤Ё"],
      "max-lenght": 5,
      "rotate": 270,
    },
    "pulseaudio": {
      "scroll-step": 5, // %, can be a float
      "format": "{icon}",
      "format-bluetooth": "пЉ” {icon} {volume}%",
      "format-bluetooth-muted": "п‘¦ пЉ” {icon} {format_source}",
      "format-muted": "п‘¦ ",
      "format-icons": {
        "headphone": "у°‹‹",
        "hands-free": "у°‹‹",
        "headset": "у°‹‹",
        "phone": "п‚•",
        "portable": "п‚•",
        "car": "п†№",
        "default": ["у°•ї", "у°–Ђ", "у°•ѕ", "у±„ "],
      },
      "on-click": "pavucontrol",
      "on-click-right": "foot -a pw-top pw-top",
    },
  },
]
